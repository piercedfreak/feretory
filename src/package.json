{
  "name": "feretory",
  "version": "1.3.0",
  "main": "main.js",
  "author": "piercedfreak",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/piercedfreak/feretory",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.piercedfreak.feretory",
    "productName": "feretory",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": "assets/installerSidebar.bmp",
      "installerHeader": "assets/installerHeader.bmp"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
