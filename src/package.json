{
  "name": "feretory",
  "productName": "feretory",
  "version": "1.6.0",
  "description": "feretory - simple scored scanner",
  "main": "main.js",
  "author": "piercedfreak",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "cheerio": "^1.1.0",
    "electron-store": "^10.0.1"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.freak.feretory",
    "productName": "feretory",
    "artifactName": "feretory-${version}-setup.${ext}",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "package.json",
      "plugins/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "plugins",
        "to": "plugins"
      },
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "feretory"
    }
  }
}
