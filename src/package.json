{
  "name": "feretory",
  "version": "1.1.0",
  "description": "Desktop monitor for Diablo IV freebies and promotions.",
  "main": "main.js",
  "author": "piercedfreak",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/piercedfreak/feretory",
  "repository": {
    "type": "git",
    "url": "https://github.com/piercedfreak/feretory.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.piercedfreak.feretory",
    "productName": "Feretory",
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Feretory",
      "perMachine": false
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
